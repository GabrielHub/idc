{
  "name": "idc",
  "version": "0.3.5",
  "private": true,
  "description": "Interdimensional Dating Coach desktop alpha shell.",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "build:desktop": "react-router build --mode desktop && node scripts/verify-desktop-build.mjs",
    "dev": "react-router dev",
    "portrait:cutout": "python scripts/portraits/remove_background.py",
    "portrait:resize-avatars": "python scripts/portraits/resize_avatars.py",
    "portrait:standee-footing": "python scripts/portraits/build_standee_footing.py",
    "release:check": "node scripts/verify-release-readiness.mjs",
    "release:notes": "node scripts/render-release-notes.mjs",
    "start": "react-router-serve ./build/server/index.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "vp check && react-router typegen && tsc && vp test run && tauri build --ci",
    "typecheck": "react-router typegen && tsc",
    "updater:manifest": "node scripts/create-updater-manifest.mjs"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/cormorant-garamond": "^5.2.6",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/cinzel-decorative": "^5.2.8",
    "@fontsource/im-fell-english": "^5.2.6",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-http": "~2.5.9",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "ai": "^6.0.183",
    "ai-sdk-ollama": "^3.8.4",
    "isbot": "^5.1.40",
    "motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.14.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vite-plus": "0.1.21",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@10.33.3"
}
