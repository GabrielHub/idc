    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@react-router/node": "7.14.0",
    "@react-router/serve": "7.14.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-fs": "~2.5.1",
    "@tauri-apps/plugin-http": "~2.5.9",
    "ai": "^6.0.177",
    "ai-sdk-ollama": "^3.8.3",
    "isbot": "^5.1.40",
    "motion": "^12.38.0",
