{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions for the IDC: Cupid desktop window. Filesystem is scoped to saves and Gateway key storage under app local data. HTTP is scoped to local Ollama and the default Vercel AI Gateway URL.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:allow-mkdir",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-remove",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPLOCALDATA/saves" },
        { "path": "$APPLOCALDATA/saves/**" },
        { "path": "$APPLOCALDATA/secrets" },
        { "path": "$APPLOCALDATA/secrets/**" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:11434/*" },
        { "url": "http://localhost:11434/*" },
        { "url": "https://ai-gateway.vercel.sh/*" }
      ]
    }
  ]
}
